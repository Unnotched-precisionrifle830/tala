      "title": "Total Intents Ingested",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(tala_intents_total{vertical=~\"$vertical\"})",
          "legendFormat": "Total Intents",
          "refId": "A"
