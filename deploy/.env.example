# TALA Simulation Configuration
# Copy to .env and adjust as needed:  cp .env.example .env

# Ingest rate per domain (milliseconds between intents)
INCIDENT_RATE_MS=400
DEPLOY_RATE_MS=300
OBSERVE_RATE_MS=200
PROVISION_RATE_MS=350

# Chaos engineering parameters
CHAOS_INTERVAL_S=60
CHAOS_PROBABILITY=0.15

# Grafana admin password (change before exposing publicly)
GRAFANA_PASSWORD=change_me
